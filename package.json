{
  "name": "use-pretext",
  "version": "0.1.0",
  "description": "Vue 3 composables for @chenglou/pretext text measurement and line layout.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "peerDependencies": {
    "@chenglou/pretext": "^0.0.2",
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@chenglou/pretext": "^0.0.2",
    "@vitejs/plugin-vue": "^5.2.4",
    "tsup": "^8.5.0",
    "typescript": "^5.8.2",
    "vite": "^6.3.2",
    "vitest": "^3.1.1",
    "vue": "^3.5.13"
  },
  "scripts": {
    "build": "tsup",
    "check": "tsc --noEmit",
    "demo": "vite",
    "test": "vitest run"
  },
  "keywords": [
    "vue",
    "vue3",
    "composable",
    "pretext",
    "text-layout",
    "text-measurement",
    "vite"
  ]
}
